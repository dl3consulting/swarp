{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__swarp__swarp_deploy_router",
        "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/confirm-cost.sh" }]
      },
      {
        "matcher": "mcp__swarp__swarp_deploy",
        "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/confirm-cost.sh" }]
      },
      {
        "matcher": "mcp__swarp__swarp_destroy",
        "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/confirm-cost.sh" }]
      }
    ]
  }
}
